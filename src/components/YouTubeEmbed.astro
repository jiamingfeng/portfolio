---
// Lazy-loading YouTube facade: shows a poster thumbnail and only injects the
// iframe on click. Keeps first paint fast (no third-party iframe until wanted).
interface Props {
  id: string;
  title?: string;
}
const { id, title = 'Video' } = Astro.props;
// maxresdefault falls back to hqdefault via onerror below.
const thumb = `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
---

<div class="yt" data-id={id} data-title={title}>
  <button class="yt-btn" type="button" aria-label={`Play: ${title}`}>
    <img
      class="yt-thumb"
      src={thumb}
      alt={title}
      loading="lazy"
      width="1280"
      height="720"
      onerror="this.onerror=null;this.src=`https://i.ytimg.com/vi/${this.closest('.yt').dataset.id}/hqdefault.jpg`"
    />
    <span class="yt-play" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="34" height="34"><path fill="currentColor" d="M8 5v14l11-7z" /></svg>
    </span>
    <span class="yt-overlay"></span>
  </button>
  {title && <p class="yt-caption">{title}</p>}
</div>

<style>
  .yt {
    width: 100%;
  }
  .yt-btn {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    background: var(--bg-card);
    padding: 0;
  }
  .yt-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, opacity 0.3s ease;
  }
  .yt-btn:hover .yt-thumb {
    transform: scale(1.04);
    opacity: 0.85;
  }
  .yt-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 40%, rgba(4, 6, 10, 0.5));
  }
  .yt-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: #04222b;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 0 0 var(--accent-glow);
    transition: transform 0.2s ease, box-shadow 0.3s ease;
  }
  .yt-btn:hover .yt-play {
    transform: scale(1.08);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 0 14px var(--accent-glow);
  }
  .yt-play svg {
    margin-left: 4px;
  }
  .yt-caption {
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: block;
  }
</style>

<script>
  document.querySelectorAll('.yt').forEach((el) => {
    const btn = el.querySelector('.yt-btn');
    btn?.addEventListener('click', () => {
      const id = (el as HTMLElement).dataset.id;
      const title = (el as HTMLElement).dataset.title ?? 'Video';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = title;
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      btn.replaceWith(iframe);
    });
  });
</script>
