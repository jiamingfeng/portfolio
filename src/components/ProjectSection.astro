---
import type { Project } from '../data/projects';
import YouTubeEmbed from './YouTubeEmbed.astro';
import VideoLoop from './VideoLoop.astro';

interface Props {
  project: Project;
  index: number;
}
const { project, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');

const featured = project.media[0];
const rest = project.media.slice(1);
const hasMedia = project.media.length > 0;
---

<article class="project reveal" id={project.slug}>
  <div class="project-head">
    <span class="project-num">{num}</span>
    <div>
      <h3 class="project-title">{project.title}</h3>
      <p class="project-role">{project.role} · <span class="project-period">{project.period}</span></p>
    </div>
  </div>

  <div class:list={['project-body', { 'no-media': !hasMedia }]}>
    <div class="project-info">
      <p class="project-blurb">{project.blurb}</p>
      <ul class="project-points">
        {project.contributions.map((c) => <li>{c}</li>)}
      </ul>
      <div class="project-links">
        {project.link && (
          <a href={project.link.url} target="_blank" rel="noopener noreferrer" class="project-link">
            {project.link.label} ↗
          </a>
        )}
        {project.officialFootage && <span class="badge">Official footage</span>}
      </div>
    </div>

    {hasMedia && (
      <div class="project-media">
        {featured.type === 'youtube' ? (
          <YouTubeEmbed id={featured.id} title={featured.title} />
        ) : (
          <VideoLoop slug={project.slug} src={featured.src} poster={featured.poster} title={featured.title} />
        )}

        {rest.length > 0 && (
          <div class="media-grid">
            {rest.map((m) =>
              m.type === 'youtube' ? (
                <YouTubeEmbed id={m.id} title={m.title} />
              ) : (
                <VideoLoop slug={project.slug} src={m.src} poster={m.poster} title={m.title} />
              )
            )}
          </div>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .project {
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
    border-top: 1px solid var(--border);
  }
  .project-head {
    display: flex;
    gap: 1.1rem;
    align-items: baseline;
    margin-bottom: 2rem;
  }
  .project-num {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--accent);
    padding-top: 0.35rem;
  }
  .project-title {
    font-size: clamp(1.5rem, 3.4vw, 2.3rem);
  }
  .project-role {
    color: var(--text-dim);
    font-size: 0.98rem;
    margin-top: 0.35rem;
  }
  .project-period {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-faint);
  }

  .project-body {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.4fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }
  .project-body.no-media {
    grid-template-columns: 1fr;
    max-width: 70ch;
  }

  .project-blurb {
    font-size: 1.18rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }
  .project-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .project-points li {
    position: relative;
    padding-left: 1.35rem;
    color: var(--text-dim);
    font-size: 0.98rem;
  }
  .project-points li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .project-links {
    margin-top: 1.4rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .project-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
  }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    border: 1px solid var(--border-bright);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }

  .project-media {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .media-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .project-body {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 540px) {
    .media-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
